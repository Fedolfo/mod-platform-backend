{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Nest Framework",
      "args": [
        "${workspaceFolder}/src/main.ts"
      ],
      "runtimeArgs": [
        "--nolazy",
        "-r",
        "ts-node/register",
        "-r",
        "tsconfig-paths/register"
      ],
      "sourceMaps": true,
      "cwd": "${workspaceRoot}",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development",
        "PORT": "3000",
        "DB_TYPE": "postgres",
        "DB_HOST": "localhost",
        "DB_PORT": "5433",
        "DB_USERNAME": "postgres-design-furniture",
        "DB_PASSWORD": "postgres123",
        "DB_DATABASE": "design_furniture_dev",
        "DB_SYNCHRONIZE": "true",
        "DB_LOGGING": "true"
      },
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Debug NestJS (Docker)",
      "port": 9222,
      "address": "localhost",
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/app",
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}